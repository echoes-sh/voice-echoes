OPENAI_API_KEY=sk-your-key-here

# Hotkey to toggle recording (default: F13)
# Examples: F13, F14, Super+Shift+R, Ctrl+Alt+Space
HOTKEY=F13

# Global key to cancel current recording without sending to OpenAI (default: Ctrl+C)
# Active only while recording
CANCEL_HOTKEY=Ctrl+C

# Microphone device ID (default: system default mic)
# Set via the Settings UI — do not edit manually
MIC_DEVICE_ID=default
