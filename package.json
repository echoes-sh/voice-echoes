{
  "name": "voice-echoes",
  "version": "1.0.5",
  "description": "Voice-to-text desktop app with system tray",
  "author": {
    "name": "ITBenko",
    "email": "contact@echoes.sh"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.voice-echoes.app",
    "productName": "Voice Echoes",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "openai": "^4.47.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "electron-builder": "^25.0.0"
  }
}
